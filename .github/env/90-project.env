# ================================================================================================
# 🏗️ PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-safe-conversion
# Load Order: 90 (loaded late, overrides defaults from 00–20 files)
#
# This file contains project-specific configuration that differs from the defaults.
# Only include variables that need to be overridden — defaults are inherited from
# earlier env files (00-core.env, 10-coverage.env, etc.).
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE CONFIGURATION OVERRIDES
# ================================================================================================

# Coverage Provider Selection (codecov for this project)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# Coverage Exclusions (merged from project needs + codecov.yml ignore paths)
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,docs/,example/,examples/,mocks/,plans/,test/,testing/,testdata/,vendor/
